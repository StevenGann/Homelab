# Heimdall stack environment — example only.
#
# Authoritative source: Heimdall/secrets/env.sops.yaml (SOPS+age encrypted).
# Decrypt at deploy time:
#   SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt \
#     sops --decrypt Heimdall/secrets/env.sops.yaml > Heimdall/.env
# The decrypted .env is .gitignored.

# --- Komodo Core ---
