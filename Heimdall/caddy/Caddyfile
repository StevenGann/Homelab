# Heimdall — Caddyfile
#
# Phase 2 scaffold: HTTPS via internal CA for *.lab hostnames; one routed service (komodo.lab)
# satisfies the Phase 2 end-to-end self-test gate.
#
# Phase 3 adds per-service `<service>.lab { reverse_proxy <pi-1>:<nodeport> ... }` blocks.
# See Heimdall/docs/runbooks/adding-a-route.md for the per-route pattern.
#
# Lives at /etc/caddy/Caddyfile inside the container (bind-mounted read-only).

{
    # Global options.
    # auto_https disable_redirects: avoids ambiguity with the :80 file_server block below
    # by preventing Caddy from auto-installing an HTTP→HTTPS redirect on every site.
    # Internal CA means no Let's Encrypt rate-limit window to worry about.
    auto_https disable_redirects

    # No `email` directive — internal CA does not need a contact for ACME registration.
}

# ─── LAN-only HTTP listener: distribute the internal-CA root certificate ──────────────
#
# nftables already restricts :80 to source 192.168.10.0/24 (see Heimdall/hostconf/nftables.conf),
# so Caddy itself does not need to filter by source. UCG does NOT forward :80 from the WAN
# (iter-1 known concern #4), so this is intrinsically LAN-scoped.
#
# `file_server` cannot serve a single file by URL — it serves files from a directory.
# `rewrite * /root.crt` re-paths every request under `/ca.crt` to the actual on-disk filename
# `root.crt`, then `file_server` reads it from the configured `root`.
#
# Internal-CA root storage location: /data/caddy/pki/authorities/local/root.crt
# (Caddy's documented internal-CA path; /data is the Compose volume mount.)

:80 {
    handle /ca.crt {
        rewrite * /root.crt
        file_server {
            root /data/caddy/pki/authorities/local
        }
    }

    # Anything else on :80 → 404. We do NOT do HTTP-01 ACME (internal CA default).
    handle {
        respond 404
    }
}

# ─── Komodo Core UI ───────────────────────────────────────────────────────────────────
#
# Phase 2 end-to-end self-test: from a LAN client with the internal-CA root trusted,
# `https://komodo.lab` returns the Komodo Core UI. This route is part of Phase 2's scaffold,
# not a Phase 3 addition, because it's the acceptance gate.

komodo.lab {
    tls internal

    # Single local upstream — passive failure detection (Caddy's default) is enough.
    # No active health probe configured: Komodo v2.2.0 doesn't expose a stable
    # /health endpoint, and for one upstream there's nothing to load-balance away
    # from anyway. Multi-upstream Phase 3 routes (NodePort fanout) should add an
    # active health check on a per-service-known-good path — see adding-a-route.md.
    reverse_proxy 127.0.0.1:9120
}

# ─── Authentik (SSO IdP) ──────────────────────────────────────────────────────────────
#
# Fronts the Authentik server (separate Compose project, published on
# 127.0.0.1:9180). Authentik reads X-Forwarded-Proto from this proxy to build
# correct https:// OIDC issuer/redirect URLs.
#   - auth.lab            : admin tier (WiFiman VPN), internal-CA cert.
#   - auth.stevengann.com : public tier — the Cloudflare Tunnel dials this Caddy
#     origin (noTLSVerify), Cloudflare's edge presents the real public cert. Caddy
#     mints an internal cert here too; cloudflared ignores its trust.

auth.lab, auth.stevengann.com {
    tls internal
    reverse_proxy 127.0.0.1:9180
}

# ─── Public Jellyfin (direct, NOT via Cloudflare) ─────────────────────────────────────
#
# Operator chose to keep Jellyfin off the Cloudflare tunnel (video / ToS §2.8) and
# expose it directly. ATTACK-SURFACE ISOLATION is the point of the explicit `:7443`:
# this listener serves ONLY jf.stevengann.com. The UCG forwards WAN TCP 443 →
# 192.168.10.4:7443, so a WAN client can reach *only* this block — never the .lab
# admin UIs or auth.stevengann.com (those live on :443/:80, which are NOT WAN-forwarded).
# A request to :7443 with any other Host gets nothing.
#
# TLS: real public cert via Let's Encrypt TLS-ALPN-01 (validates on external :443 →
# forwarded to :7443; no DNS plugin / no port 80 needed). The cert won't issue until
# the port-forward + grey-cloud DNS (jf.stevengann.com → monolith.ddns.net) are live.
# Optionally add `email <you>` to the global block for LE expiry notices.
#
# Reachable publicly = relies entirely on Jellyfin's own (LDAP-backed) login. See
# docs/runbooks/sso-bring-up.md §8.

jf.stevengann.com:7443 {
    reverse_proxy 192.168.10.247:30013
}

# ─── Ollama (on Thoth, GPU host) ──────────────────────────────────────────────────────
#
# Reverse-proxies ollama.lab → the Ollama container on Thoth (192.168.10.144:11434).
# flush_interval -1 disables response buffering so token streaming is immediate.
# Ollama's OLLAMA_ORIGINS allows http(s)://ollama.lab past its origin guard.

ollama.lab {
    tls internal
    reverse_proxy 192.168.10.144:11434 {
        flush_interval -1
    }
}

# ─── OpenWebUI (chat UI for Ollama, on Thoth) ─────────────────────────────────────────
# Has its own login. WebSocket (socket.io) + streamed tokens — flush_interval -1.
openwebui.lab {
    tls internal
    reverse_proxy 192.168.10.144:3000 {
        flush_interval -1
    }
}

# ─── ComfyUI (image gen, on Thoth — GPU) ──────────────────────────────────────────────
# No native auth — LAN/VPN only. Uses a /ws WebSocket for queue/progress (Caddy
# proxies WS automatically).
comfyui.lab {
    tls internal
    reverse_proxy 192.168.10.144:8188 {
        flush_interval -1
    }
}

# ─── Hermes Agent (Alfred) Dashboard ──────────────────────────────────────────────────
# Proxies to the hermes-dashboard LoadBalancer (basic-auth protected nginx sidecar).
alfred.lab {
    tls internal
    reverse_proxy 192.168.10.52:80
}

# ─── Phase 3 routes go below this line ────────────────────────────────────────────────
#
# Pattern for HTTP services on the k3s cluster (NodePort fanout across all Pi nodes):
#
# service.lab {
#     tls internal
#     reverse_proxy 192.168.10.101:30001 192.168.10.102:30001 192.168.10.103:30001 \
#                   192.168.10.104:30001 192.168.10.105:30001 192.168.10.106:30001 \
#                   192.168.10.107:30001 192.168.10.108:30001 192.168.10.109:30001 \
#                   192.168.10.110:30001 {
#         lb_policy least_conn
#         health_uri /healthz
#         health_interval 30s
#         fail_duration 60s
#     }
# }
#
# Pattern for L4 (game servers etc.) — see the layer4 docs at github.com/mholt/caddy-l4
# and adding-a-route.md for the JSON config form (or use the Caddyfile `layer4` directive
# if the syntax has stabilized in your pinned plugin version).
