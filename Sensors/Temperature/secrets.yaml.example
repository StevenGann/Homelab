# ESPHome secrets — TEMPLATE. Copy to `secrets.yaml` (gitignored) and fill in.
# `secrets.yaml` is read in plaintext by ESPHome at compile time.
# Target end-state: encrypt as `secrets.sops.yaml` (SOPS+age) once a key exists;
# see docs/plan/implementation-plan.md §6.

# --- WiFi ---
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
fallback_ap_password: "FALLBACK_AP_PASSWORD"      # >=8 chars, for recovery hotspot

# --- Home Assistant native API ---
# Generate: openssl rand -base64 32
api_encryption_key: "BASE64_32_BYTE_KEY=="

# --- OTA (over-the-air updates) ---
ota_password: "STRONG_OTA_PASSWORD"

# --- MQTT broker ---
mqtt_broker: "192.168.10.x"                       # broker host/IP
mqtt_username: "MQTT_USERNAME"
mqtt_password: "MQTT_PASSWORD"
